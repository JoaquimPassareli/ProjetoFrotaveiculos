{
	"name": "projeto-frota-veiculos",
	"version": "1.0.0",
	"private": true,
	"workspaces": [
		"client",
		"server"
	],
	"scripts": {
		"dev": "concurrently \"npm run dev -w server\" \"npm run dev -w client\"",
		"dev:client": "npm run dev -w client",
		"dev:server": "npm run dev -w server",
		"build": "npm run build -w client"
	},
	"devDependencies": {
		"concurrently": "^9.0.1"
	}
}
